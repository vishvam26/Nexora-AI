# ==============================================================================
# Nexora-AI Environment Configuration Example
# ==============================================================================
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit '.env' to git repository.

# --- General ---
PROJECT_NAME="Nexora-AI"
ENV="development" # development, staging, production
DEBUG=true

# --- Backend Config ---
BACKEND_HOST="0.0.0.0"
BACKEND_PORT=8000
SECRET_KEY="replace-this-with-a-very-secure-random-string"
LOG_LEVEL="INFO"

# --- Frontend Config ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL="http://localhost:8000"

# --- Database Configurations ---
# Example for PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/nexora_db"

# Example for Redis (Caching & Task Queues)
REDIS_URL="redis://localhost:6379/0"

# --- AI & LLM Providers ---
# Gemini API
GEMINI_API_KEY=""

# OpenAI API (Optional)
OPENAI_API_KEY=""

# Anthropic API (Optional)
ANTHROPIC_API_KEY=""

# Hugging Face Access Token (For downloading models)
HUGGINGFACE_TOKEN=""
