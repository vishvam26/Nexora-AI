# ==============================================================================
# Nexora AI Production Environment Configuration Example
# Copy this file to '.env.production' and update values before deploying.
# ==============================================================================

# --- PostgreSQL Connection details ---
POSTGRES_USER=nexora
POSTGRES_PASSWORD=CHOOSE_A_SAFE_PASSWORD_HERE
POSTGRES_DB=nexora_ai
# Postgres host points to the compose container name in production
DATABASE_URL=postgresql://nexora:CHOOSE_A_SAFE_PASSWORD_HERE@postgres:5432/nexora_ai

# --- API Security Configuration ---
# Generate key with command: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_CRYPTOGRAPHICALLY_SECURE_HEX_STRING_HERE
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- OpenAI API Credentials ---
OPENAI_API_KEY=sk-proj-...

# --- Qdrant Vector database ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# If using Qdrant Cloud or secure cluster:
# QDRANT_API_KEY=your-api-key

# --- NextJS Frontend Configuration ---
# Points to Nginx proxy mapping endpoint (local proxy address in client browser context)
NEXT_PUBLIC_API_URL=http://localhost/api/v1
# If deploying behind SSL domain:
# NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1

# --- Sentry & Monitoring Configuration (Optional) ---
# SENTRY_DSN=https://your-sentry-dsn-key@sentry.io/project-id
# ENABLE_PROMETHEUS=true

