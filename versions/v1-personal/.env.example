APP_NAME="Nexora AI"
APP_VERSION="1.0.0"
DEBUG=True

# ─────────────────────────────────────────────────
# V1 — PERSONAL EDITION
# Single user mode. No team or enterprise features.
# ─────────────────────────────────────────────────
APP_MODE=PERSONAL

DATABASE_URL=sqlite:///./nexora_ai.db
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI Provider — choose one
AI_PROVIDER=gemini
OPENAI_API_KEY=YOUR_OPENAI_KEY
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

GOOGLE_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash

OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Local Nexora Model (optional)
NEXORA_MODEL_ID=vishvam26/nexora-qwen3.5-4b-merged
NEXORA_BASE_MODEL_ID=vishvam26/nexora-qwen3.5-4b-merged
NEXORA_DEVICE=auto
NEXORA_MAX_NEW_TOKENS=512
NEXORA_TEMPERATURE=0.7
NEXORA_TOP_P=0.9
HF_TOKEN=YOUR_HF_TOKEN

# Memory
MAX_HISTORY_MESSAGES=10
SUMMARY_TRIGGER=20

# RAG
RAG_TOP_K=10
MAX_CONTEXT_TOKENS=4000
SIMILARITY_THRESHOLD=0.1
ENABLE_RERANKING=true
HYBRID_VECTOR_WEIGHT=0.70
HYBRID_KEYWORD_WEIGHT=0.30
GRAPH_MAX_DEPTH=2
CONFIDENCE_THRESHOLD=0.50

# ─────────────────────────────────────────────────
# Feature flags are auto-derived from APP_MODE
# PERSONAL → ENABLE_TEAM=false, ENABLE_ENTERPRISE=false
# ─────────────────────────────────────────────────
