APP_NAME="Nexora AI"
APP_VERSION="1.0.0"
DEBUG=True

# ─────────────────────────────────────────────────
# App Mode: PERSONAL | TEAM | ENTERPRISE
# Controls which permission layer is active.
# ─────────────────────────────────────────────────
APP_MODE=PERSONAL

DATABASE_URL=postgresql://nexora:nexora123@localhost:5432/nexora_ai
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI Configuration
AI_PROVIDER=openai
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

GOOGLE_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Local Nexora Model Configuration
NEXORA_MODEL_ID=vishvam26/nexora-qwen3.5-4b-lora-v1
NEXORA_BASE_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
NEXORA_DEVICE=auto
NEXORA_MAX_NEW_TOKENS=512
NEXORA_TEMPERATURE=0.7
NEXORA_TOP_P=0.9
HF_TOKEN=YOUR_HF_TOKEN_HERE

# Memory Configuration
MAX_HISTORY_MESSAGES=10
SUMMARY_TRIGGER=20

# Prompt Configuration
SYSTEM_PROMPT_PATH=app/prompts/system_prompt.txt
DEVELOPER_PROMPT_PATH=app/prompts/developer_prompt.txt

# RAG Configuration
RAG_TOP_K=10
MAX_CONTEXT_TOKENS=4000
SIMILARITY_THRESHOLD=0.1
ENABLE_RERANKING=true
HYBRID_VECTOR_WEIGHT=0.70
HYBRID_KEYWORD_WEIGHT=0.30
GRAPH_MAX_DEPTH=2
CONFIDENCE_THRESHOLD=0.50

# ─────────────────────────────────────────────────
# Feature Flags (derived automatically from APP_MODE)
# DO NOT set these manually — they are computed in code:
#   PERSONAL   ⇒ ENABLE_TEAM=false, ENABLE_ENTERPRISE=false
#   TEAM       ⇒ ENABLE_TEAM=true,  ENABLE_ENTERPRISE=false
#   ENTERPRISE ⇒ ENABLE_TEAM=true,  ENABLE_ENTERPRISE=true
# ─────────────────────────────────────────────────
