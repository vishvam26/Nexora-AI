APP_NAME="Nexora AI"
APP_VERSION="1.0.0"
DEBUG=True
DATABASE_URL=postgresql://nexora:nexora123@localhost:5432/nexora_ai
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI Configuration
AI_PROVIDER=openai
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

GOOGLE_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Local Nexora Model Configuration
NEXORA_MODEL_ID=vishvam26/nexora-qwen3.5-4b-lora-v1
NEXORA_BASE_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
NEXORA_DEVICE=auto
NEXORA_MAX_NEW_TOKENS=512
NEXORA_TEMPERATURE=0.7
NEXORA_TOP_P=0.9

# Memory Configuration
MAX_HISTORY_MESSAGES=10
SUMMARY_TRIGGER=20

# Prompt Configuration
SYSTEM_PROMPT_PATH=app/prompts/system_prompt.txt
DEVELOPER_PROMPT_PATH=app/prompts/developer_prompt.txt



